# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service Role key bypasses RLS — required for server-side writes (pvp, coop, friends)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection — used for auto-migration on startup.
# Get from Supabase Dashboard > Settings > Database > Connection string (URI mode).
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Debug logging — set to "true" to enable verbose debug logs, "false" for production
DEBUG=false
