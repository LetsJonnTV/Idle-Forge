# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service Role key bypasses RLS — required for server-side writes (pvp, coop, friends)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection — target this at Cloud SQL Postgres after migration.
# Example: postgresql://idle_forge_app:[password]@/[database]?host=/cloudsql/[project]:[region]:[instance]
DATABASE_URL=postgresql://idle_forge_app:[password]@/idle_forge?host=/cloudsql/astral-theory-449511-c1:europe-west3:idle-forge-pg

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Debug logging — set to "true" to enable verbose debug logs, "false" for production
DEBUG=false
