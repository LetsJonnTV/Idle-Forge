# PostgreSQL connection string (Cloud SQL over Unix socket on Cloud Run)
# Example: postgresql://idle_forge_app:[password]@/idle_forge?host=/cloudsql/[project]:[region]:[instance]
DATABASE_URL=postgresql://idle_forge_app:[password]@/idle_forge?host=/cloudsql/astral-theory-449511-c1:europe-west3:idle-forge-pg

# JWT Secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Debug logging — set to "true" to enable verbose debug logs, "false" for production
DEBUG=false
